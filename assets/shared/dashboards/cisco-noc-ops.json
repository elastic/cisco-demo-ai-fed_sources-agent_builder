{
  "title": "Cisco NOC Command Center",
  "description": "Branch 4471 incident view — Meraki + BGP/DNA signals on Elastic Serverless Search.",
  "tags": ["cisco", "noc", "serverless-search", "workshop"],
  "time_range": { "from": "now-24h", "to": "now" },
  "options": {
    "use_margins": true,
    "sync_colors": true,
    "sync_cursor": true,
    "sync_tooltips": true,
    "hide_panel_titles": false,
    "auto_apply_filters": true,
    "hide_panel_borders": false
  },
  "query": { "expression": "", "language": "kql" },
  "filters": [],
  "panels": [
    {
      "id": "cisco-noc-md-hero",
      "type": "markdown",
      "grid": { "x": 0, "y": 0, "w": 48, "h": 4 },
      "config": {
        "content": "**Incident focus:** Branch **4471** (Dallas) — Meraki AP offline + BGP down on `edge-dfw-01`. Panels use ES|QL against your Serverless Search indices. Next: AI Assistant on `cisco-network-kb`, or Workflows → **Cisco Branch 4471 — Splunk O11Y A2A RCA**.",
        "settings": { "open_links_in_new_tab": true }
      }
    },
    {
      "id": "cisco-noc-kpi-meraki-offline",
      "type": "vis",
      "grid": { "x": 0, "y": 4, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "type": "metric",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events\n| WHERE @timestamp > NOW() - 24 hours AND event_type == \"device.offline\"\n| STATS `Meraki offline (24h)` = COUNT(*)"
        },
        "metrics": [{ "type": "primary", "column": "Meraki offline (24h)" }]
      }
    },
    {
      "id": "cisco-noc-kpi-bgp",
      "type": "vis",
      "grid": { "x": 12, "y": 4, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "type": "metric",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-events\n| WHERE @timestamp > NOW() - 24 hours AND event_type == \"bgp.session_down\"\n| STATS `BGP session down (24h)` = COUNT(*)"
        },
        "metrics": [{ "type": "primary", "column": "BGP session down (24h)" }]
      }
    },
    {
      "id": "cisco-noc-kpi-4471",
      "type": "vis",
      "grid": { "x": 24, "y": 4, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "type": "metric",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events, cisco-network-events\n| WHERE @timestamp > NOW() - 24 hours\n| EVAL site_name = COALESCE(site, `cisco.site`)\n| WHERE site_name LIKE \"*4471*\"\n| STATS `Branch 4471 events (24h)` = COUNT(*)"
        },
        "metrics": [{ "type": "primary", "column": "Branch 4471 events (24h)" }]
      }
    },
    {
      "id": "cisco-noc-kpi-kb",
      "type": "vis",
      "grid": { "x": 36, "y": 4, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "type": "metric",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS `KB runbooks indexed` = COUNT(*)"
        },
        "metrics": [{ "type": "primary", "column": "KB runbooks indexed" }]
      }
    },
    {
      "id": "cisco-noc-meraki-timeline",
      "type": "vis",
      "grid": { "x": 0, "y": 9, "w": 28, "h": 12 },
      "config": {
        "title": "Meraki events over time (by type)",
        "type": "xy",
        "axis": {
          "x": {
            "scale": "temporal",
            "domain": { "type": "fit", "rounding": false },
            "title": { "visible": false }
          },
          "y": { "title": { "visible": false } }
        },
        "layers": [
          {
            "type": "area_stacked",
            "data_source": {
              "type": "esql",
              "query": "FROM cisco-meraki-events\n| WHERE @timestamp <= ?_tend AND @timestamp > ?_tstart\n| STATS count = COUNT(*) BY event_type, BUCKET(@timestamp, 24, ?_tstart, ?_tend)"
            },
            "x": {
              "column": "BUCKET(@timestamp, 24, ?_tstart, ?_tend)",
              "label": "@timestamp"
            },
            "y": [{ "column": "count" }],
            "breakdown_by": { "column": "event_type" }
          }
        ]
      }
    },
    {
      "id": "cisco-noc-by-site",
      "type": "vis",
      "grid": { "x": 28, "y": 9, "w": 20, "h": 12 },
      "config": {
        "title": "Top sites by event volume",
        "type": "xy",
        "axis": {
          "x": { "title": { "visible": false } },
          "y": { "title": { "visible": false } }
        },
        "layers": [
          {
            "type": "bar_horizontal",
            "data_source": {
              "type": "esql",
              "query": "FROM cisco-meraki-events, cisco-network-events\n| WHERE @timestamp > NOW() - 24 hours\n| EVAL site_name = COALESCE(site, `cisco.site`)\n| STATS count = COUNT(*) BY site_name\n| SORT count DESC\n| LIMIT 10"
            },
            "x": { "column": "site_name" },
            "y": [{ "column": "count" }]
          }
        ]
      }
    },
    {
      "id": "cisco-noc-meraki-heatmap",
      "type": "vis",
      "grid": { "x": 0, "y": 21, "w": 24, "h": 12 },
      "config": {
        "title": "Meraki activity heatmap (hour × event type)",
        "type": "heatmap",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events\n| WHERE @timestamp > NOW() - 24 hours\n| EVAL hour = DATE_EXTRACT(\"hour_of_day\", @timestamp)\n| STATS count = COUNT(*) BY event_type, hour"
        },
        "x": { "column": "hour" },
        "y": { "column": "event_type" },
        "metric": { "column": "count" }
      }
    },
    {
      "id": "cisco-noc-net-timeline",
      "type": "vis",
      "grid": { "x": 24, "y": 21, "w": 24, "h": 12 },
      "config": {
        "title": "Network signals over time",
        "type": "xy",
        "axis": {
          "x": {
            "scale": "temporal",
            "domain": { "type": "fit", "rounding": false },
            "title": { "visible": false }
          },
          "y": { "title": { "visible": false } }
        },
        "layers": [
          {
            "type": "area",
            "data_source": {
              "type": "esql",
              "query": "FROM cisco-network-events\n| WHERE @timestamp <= ?_tend AND @timestamp > ?_tstart\n| STATS count = COUNT(*) BY BUCKET(@timestamp, 24, ?_tstart, ?_tend)"
            },
            "x": {
              "column": "BUCKET(@timestamp, 24, ?_tstart, ?_tend)",
              "label": "@timestamp"
            },
            "y": [{ "column": "count" }]
          }
        ]
      }
    },
    {
      "id": "cisco-noc-meraki-table",
      "type": "vis",
      "grid": { "x": 0, "y": 33, "w": 24, "h": 12 },
      "config": {
        "hide_title": false,
        "title": "Latest Meraki offline",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events\n| WHERE event_type == \"device.offline\"\n| SORT @timestamp DESC\n| KEEP @timestamp, site, device_name, detail\n| LIMIT 8"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "@timestamp" },
          { "column": "site" },
          { "column": "device_name" },
          { "column": "detail" }
        ],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-noc-net-table",
      "type": "vis",
      "grid": { "x": 24, "y": 33, "w": 24, "h": 12 },
      "config": {
        "hide_title": false,
        "title": "Latest network signals",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-events\n| SORT @timestamp DESC\n| KEEP @timestamp, `cisco.site`, `host.name`, event_type, message\n| LIMIT 8"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "@timestamp" },
          { "column": "cisco.site" },
          { "column": "host.name" },
          { "column": "event_type" },
          { "column": "message" }
        ],
        "styling": { "paging": 10 }
      }
    }
  ]
}
