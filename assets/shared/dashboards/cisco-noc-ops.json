{
  "title": "Cisco NOC Command Center",
  "description": "Branch 4471 incident view — Meraki + BGP/DNA signals on Elastic Serverless Search.",
  "tags": ["cisco", "noc", "serverless-search", "workshop"],
  "time_range": { "from": "now-24h", "to": "now" },
  "options": {
    "use_margins": true,
    "sync_colors": true,
    "sync_cursor": true,
    "sync_tooltips": true,
    "hide_panel_titles": false,
    "auto_apply_filters": true,
    "hide_panel_borders": false
  },
  "query": { "expression": "", "language": "kql" },
  "filters": [],
  "panels": [
    {
      "id": "cisco-noc-md-hero",
      "type": "markdown",
      "grid": { "x": 0, "y": 0, "w": 48, "h": 5 },
      "config": {
        "content": "# Cisco NOC Command Center\n\n**Incident:** Branch **4471** (Dallas) — Meraki AP offline + BGP down on `edge-dfw-01`.\n\nAll panels query your **Elastic Serverless Search** indices. Next: ES|QL + AI Assistant on `cisco-network-kb`. Also try Workflows → **Cisco Branch 4471 — Splunk O11Y A2A RCA**.",
        "settings": { "open_links_in_new_tab": true }
      }
    },
    {
      "id": "cisco-noc-kpi-meraki-offline",
      "type": "vis",
      "grid": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "config": {
        "hide_title": false,
        "title": "Meraki offline (24h)",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events\n| WHERE @timestamp > NOW() - 24 hours AND event_type == \"device.offline\"\n| STATS offline = COUNT(*)\n| KEEP offline"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [{ "column": "offline" }],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-noc-kpi-bgp",
      "type": "vis",
      "grid": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "config": {
        "hide_title": false,
        "title": "BGP session down (24h)",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-events\n| WHERE @timestamp > NOW() - 24 hours AND event_type == \"bgp.session_down\"\n| STATS bgp_down = COUNT(*)\n| KEEP bgp_down"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [{ "column": "bgp_down" }],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-noc-kpi-4471",
      "type": "vis",
      "grid": { "x": 24, "y": 5, "w": 12, "h": 8 },
      "config": {
        "hide_title": false,
        "title": "Branch 4471 events (24h)",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events, cisco-network-events\n| WHERE @timestamp > NOW() - 24 hours\n| EVAL site_name = COALESCE(site, `cisco.site`)\n| WHERE site_name LIKE \"*4471*\"\n| STATS events_4471 = COUNT(*)\n| KEEP events_4471"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [{ "column": "events_4471" }],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-noc-kpi-kb",
      "type": "vis",
      "grid": { "x": 36, "y": 5, "w": 12, "h": 8 },
      "config": {
        "hide_title": false,
        "title": "KB runbooks indexed",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS runbooks = COUNT(*)\n| KEEP runbooks"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [{ "column": "runbooks" }],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-noc-meraki-timeline",
      "type": "vis",
      "grid": { "x": 0, "y": 13, "w": 28, "h": 14 },
      "config": {
        "hide_title": false,
        "title": "Meraki events over time",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events\n| WHERE @timestamp > NOW() - 24 hours\n| STATS count = COUNT(*) BY event_type, bucket = BUCKET(@timestamp, 1 hour)\n| SORT bucket ASC\n| KEEP bucket, event_type, count"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "bucket" },
          { "column": "event_type" },
          { "column": "count" }
        ],
        "styling": { "paging": 20 }
      }
    },
    {
      "id": "cisco-noc-by-site",
      "type": "vis",
      "grid": { "x": 28, "y": 13, "w": 20, "h": 14 },
      "config": {
        "hide_title": false,
        "title": "Events by site",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events, cisco-network-events\n| WHERE @timestamp > NOW() - 24 hours\n| EVAL site_name = COALESCE(site, `cisco.site`)\n| STATS count = COUNT(*) BY site_name\n| SORT count DESC\n| LIMIT 10"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "site_name" },
          { "column": "count" }
        ],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-noc-meraki-table",
      "type": "vis",
      "grid": { "x": 0, "y": 27, "w": 24, "h": 14 },
      "config": {
        "hide_title": false,
        "title": "Latest Meraki offline",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-meraki-events\n| WHERE event_type == \"device.offline\"\n| SORT @timestamp DESC\n| KEEP @timestamp, site, device_name, detail\n| LIMIT 8"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "@timestamp" },
          { "column": "site" },
          { "column": "device_name" },
          { "column": "detail" }
        ],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-noc-net-table",
      "type": "vis",
      "grid": { "x": 24, "y": 27, "w": 24, "h": 14 },
      "config": {
        "hide_title": false,
        "title": "Latest network signals",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-events\n| SORT @timestamp DESC\n| KEEP @timestamp, `cisco.site`, `host.name`, event_type, message\n| LIMIT 8"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "@timestamp" },
          { "column": "cisco.site" },
          { "column": "host.name" },
          { "column": "event_type" },
          { "column": "message" }
        ],
        "styling": { "paging": 10 }
      }
    }
  ]
}
