{
  "title": "Cisco Knowledge Base Library",
  "description": "Runbook coverage on Elastic Serverless Search (cisco-network-kb).",
  "tags": ["cisco", "kb", "serverless-search", "workshop"],
  "time_range": { "from": "now-7d", "to": "now" },
  "options": {
    "use_margins": true,
    "sync_colors": true,
    "sync_cursor": true,
    "sync_tooltips": false,
    "hide_panel_titles": false,
    "auto_apply_filters": true,
    "hide_panel_borders": false
  },
  "query": { "expression": "", "language": "kql" },
  "filters": [],
  "panels": [
    {
      "id": "cisco-kb-md-hero",
      "type": "markdown",
      "grid": { "x": 0, "y": 0, "w": 48, "h": 4 },
      "config": {
        "content": "Unified runbooks in **`cisco-network-kb`**. Try: `FROM cisco-network-kb | WHERE MATCH(content, \"BGP neighbor idle\") | KEEP title, product, content | LIMIT 10`",
        "settings": { "open_links_in_new_tab": true }
      }
    },
    {
      "id": "cisco-kb-kpi-total",
      "type": "vis",
      "grid": { "x": 0, "y": 4, "w": 16, "h": 5 },
      "config": {
        "title": "",
        "type": "metric",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS `Total runbooks` = COUNT(*)"
        },
        "metrics": [{ "type": "primary", "column": "Total runbooks" }]
      }
    },
    {
      "id": "cisco-kb-kpi-meraki",
      "type": "vis",
      "grid": { "x": 16, "y": 4, "w": 16, "h": 5 },
      "config": {
        "title": "",
        "type": "metric",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| WHERE product == \"Meraki\"\n| STATS `Meraki docs` = COUNT(*)"
        },
        "metrics": [{ "type": "primary", "column": "Meraki docs" }]
      }
    },
    {
      "id": "cisco-kb-kpi-iosxe",
      "type": "vis",
      "grid": { "x": 32, "y": 4, "w": 16, "h": 5 },
      "config": {
        "title": "",
        "type": "metric",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| WHERE product == \"IOS-XE\"\n| STATS `IOS-XE docs` = COUNT(*)"
        },
        "metrics": [{ "type": "primary", "column": "IOS-XE docs" }]
      }
    },
    {
      "id": "cisco-kb-treemap",
      "type": "vis",
      "grid": { "x": 0, "y": 9, "w": 28, "h": 12 },
      "config": {
        "title": "Runbook coverage (product → category)",
        "type": "treemap",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS count = COUNT(*) BY product, category"
        },
        "metrics": [{ "column": "count" }],
        "group_by": [{ "column": "product" }, { "column": "category" }]
      }
    },
    {
      "id": "cisco-kb-by-product",
      "type": "vis",
      "grid": { "x": 28, "y": 9, "w": 20, "h": 12 },
      "config": {
        "title": "Runbooks by product",
        "type": "pie",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS count = COUNT(*) BY product"
        },
        "metrics": [{ "column": "count" }],
        "group_by": [{ "column": "product" }],
        "styling": { "donut_hole": "m" }
      }
    },
    {
      "id": "cisco-kb-by-category",
      "type": "vis",
      "grid": { "x": 0, "y": 21, "w": 28, "h": 11 },
      "config": {
        "title": "Runbooks by category",
        "type": "xy",
        "axis": {
          "x": { "title": { "visible": false } },
          "y": { "title": { "visible": false } }
        },
        "layers": [
          {
            "type": "bar_horizontal",
            "data_source": {
              "type": "esql",
              "query": "FROM cisco-network-kb\n| STATS count = COUNT(*) BY category\n| SORT count DESC"
            },
            "x": { "column": "category" },
            "y": [{ "column": "count" }]
          }
        ]
      }
    },
    {
      "id": "cisco-kb-tagcloud",
      "type": "vis",
      "grid": { "x": 28, "y": 21, "w": 20, "h": 11 },
      "config": {
        "title": "Category cloud",
        "type": "tag_cloud",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS count = COUNT(*) BY category"
        },
        "tag_by": { "column": "category" },
        "metric": { "column": "count" }
      }
    },
    {
      "id": "cisco-kb-catalog",
      "type": "vis",
      "grid": { "x": 0, "y": 32, "w": 48, "h": 14 },
      "config": {
        "hide_title": false,
        "title": "Runbook catalog",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| KEEP title, product, category, resolution_type\n| SORT product ASC, title ASC\n| LIMIT 50"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "title" },
          { "column": "product" },
          { "column": "category" },
          { "column": "resolution_type" }
        ],
        "styling": { "paging": 20 }
      }
    }
  ]
}
