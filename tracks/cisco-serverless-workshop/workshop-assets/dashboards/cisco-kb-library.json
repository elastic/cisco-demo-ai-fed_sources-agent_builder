{
  "title": "Cisco Knowledge Base Library",
  "description": "Runbook coverage on Elastic Serverless Search (cisco-network-kb).",
  "tags": ["cisco", "kb", "serverless-search", "workshop"],
  "time_range": { "from": "now-7d", "to": "now" },
  "options": {
    "use_margins": true,
    "sync_colors": true,
    "sync_cursor": true,
    "sync_tooltips": false,
    "hide_panel_titles": false,
    "auto_apply_filters": true,
    "hide_panel_borders": false
  },
  "query": { "expression": "", "language": "kql" },
  "filters": [],
  "panels": [
    {
      "id": "cisco-kb-md-hero",
      "type": "markdown",
      "grid": { "x": 0, "y": 0, "w": 48, "h": 5 },
      "config": {
        "content": "# Cisco Knowledge Base Library\n\nUnified runbooks in **`cisco-network-kb`**.\n\nTry: `FROM cisco-network-kb | WHERE MATCH(content, \"BGP neighbor idle\") | KEEP title, product, content | LIMIT 10`",
        "settings": { "open_links_in_new_tab": true }
      }
    },
    {
      "id": "cisco-kb-kpi-total",
      "type": "vis",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "config": {
        "hide_title": false,
        "title": "Total runbooks",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS docs = COUNT(*)\n| KEEP docs"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [{ "column": "docs" }],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-kb-kpi-meraki",
      "type": "vis",
      "grid": { "x": 16, "y": 5, "w": 16, "h": 8 },
      "config": {
        "hide_title": false,
        "title": "Meraki docs",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| WHERE product == \"Meraki\"\n| STATS meraki_docs = COUNT(*)\n| KEEP meraki_docs"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [{ "column": "meraki_docs" }],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-kb-kpi-iosxe",
      "type": "vis",
      "grid": { "x": 32, "y": 5, "w": 16, "h": 8 },
      "config": {
        "hide_title": false,
        "title": "IOS-XE docs",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| WHERE product == \"IOS-XE\"\n| STATS iosxe_docs = COUNT(*)\n| KEEP iosxe_docs"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [{ "column": "iosxe_docs" }],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-kb-by-product",
      "type": "vis",
      "grid": { "x": 0, "y": 13, "w": 20, "h": 14 },
      "config": {
        "hide_title": false,
        "title": "Runbooks by product",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS count = COUNT(*) BY product\n| SORT count DESC"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "product" },
          { "column": "count" }
        ],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-kb-by-category",
      "type": "vis",
      "grid": { "x": 20, "y": 13, "w": 28, "h": 14 },
      "config": {
        "hide_title": false,
        "title": "Runbooks by category",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| STATS count = COUNT(*) BY category\n| SORT count DESC"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "category" },
          { "column": "count" }
        ],
        "styling": { "paging": 10 }
      }
    },
    {
      "id": "cisco-kb-catalog",
      "type": "vis",
      "grid": { "x": 0, "y": 27, "w": 48, "h": 16 },
      "config": {
        "hide_title": false,
        "title": "Runbook catalog",
        "type": "data_table",
        "data_source": {
          "type": "esql",
          "query": "FROM cisco-network-kb\n| KEEP title, product, category, resolution_type\n| SORT product ASC, title ASC\n| LIMIT 50"
        },
        "sampling": 1,
        "ignore_global_filters": false,
        "rows": [
          { "column": "title" },
          { "column": "product" },
          { "column": "category" },
          { "column": "resolution_type" }
        ],
        "styling": { "paging": 20 }
      }
    }
  ]
}
